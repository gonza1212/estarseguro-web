---
import { getImage } from 'astro:assets';
import '@styles/global.css';
import SEO from '@components/SEO.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import WhatsAppCTA from '@components/WhatsAppCTA.astro';
import carrouselAuto from '@assets/carrousel-auto.webp';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;

const lcpImage = await getImage({
  src: carrouselAuto,
  format: 'webp',
  widths: [640, 960, 1280, 1920],
  sizes: '100vw',
  quality: 90,
});
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="preload"
      as="image"
      href={lcpImage.src}
      imagesrcset={lcpImage.srcSet.attribute}
      imagesizes="100vw"
      fetchpriority="high"
    />
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      canonical={canonical}
    />
    <script is:inline>
      (function () {
        try {
          document.documentElement.classList.remove('dark');
          if (localStorage.getItem('theme') === 'dark') {
            localStorage.setItem('theme', 'light');
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-[var(--color-background)] text-[var(--color-text)]">
    <Header />
    <main class="flex flex-1 flex-col">
      <slot />
    </main>
    <Footer />
    <WhatsAppCTA />
  </body>
</html>
