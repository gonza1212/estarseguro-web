---
import { Image } from 'astro:assets';
import logo from '@assets/logo.webp';
import Container from '@components/Container.astro';

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '';
const whatsappHref = whatsappNumber ? `https://wa.me/${whatsappNumber}` : 'https://wa.me/';
const instagramUrl = import.meta.env.PUBLIC_INSTAGRAM_URL ?? '#';
const sanCristobalUrl = import.meta.env.PUBLIC_SAN_CRISTOBAL_URL ?? '#';
const displayPhone = whatsappNumber
  ? `+${whatsappNumber.replace(/^(\d{2})(\d)(\d{2})(\d{4})(\d{0,4})$/, '$1 $2 $3 $4-$5').trim()}`
  : '+54 9 11 0000-0000';

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '#seguros-art', label: 'Seguros de ART' },
  { href: '#seguro-sepelio', label: 'Seguro de Sepelio' },
  { href: '#seguros-autos', label: 'Seguros de Autos' },
  { href: '#seguros-empresas', label: 'Seguros para Empresas' },
  { href: '#contacto', label: 'Contacto' },
];
---

<footer data-footer class="bg-[var(--color-dark)] text-white">
  <Container>
    <div class="grid grid-cols-1 gap-8 py-12 sm:grid-cols-2 lg:grid-cols-4">
      <div class="footer-anim-col" style="--anim-delay: 0ms">
        <div class="mb-4 flex items-center gap-3">
          <Image src={logo} alt="Logo de Estar Seguro" width={56} height={56} class="h-14 w-14 w-auto" />
          <div class="flex flex-col items-start leading-none">
            <span class="block text-4xl font-extrabold uppercase leading-none tracking-tight text-white">Estar</span>
            <span class="mt-px block text-3xl font-extrabold uppercase leading-none tracking-tight text-[var(--color-primary)]">Seguro</span>
          </div>
        </div>
        <p class="text-[12px] -mt-3 font-bold text-white">
          productores asesores de seguros
        </p>
        <p class="mt-4 text-md font-semibold text-white">
          Arias Alberto Gastón
        </p>
        <p class="mb-2 text-sm text-white/70">
          Matrícula: 00000
        </p>
        <p class="text-center text-base text-white/50" aria-hidden="true">—</p>
        <p class="mt-2 text-md font-semibold text-white">
          Valeria Melisa Millapinda
        </p>
        <p class="text-sm text-white/70">
          Matrícula: 00000
        </p>
      </div>

      <div class="footer-anim-col" style="--anim-delay: 200ms">
        <h3 class="mb-8 text-lg font-semibold uppercase tracking-wider text-[var(--color-primary)]">
          Enlaces
        </h3>
        <ul class="space-y-1 text-lg">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-white/80 transition-opacity hover:text-[var(--color-primary)]"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-anim-col" style="--anim-delay: 400ms">
        <h3 class="mb-8 text-lg font-semibold uppercase tracking-wider text-[var(--color-primary)]">
          Contacto
        </h3>
        <ul class="space-y-3 text-lg text-white/80">
          <li class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              class="h-4 w-4 shrink-0"
              aria-hidden="true"
              fill="currentColor"
              stroke="none"
              stroke-width="1"
            >
              <path
                d="M12 0C5.373 0 0 5.373 0 12c0 2.118.549 4.106 1.522 5.823L0 24l6.335-1.652A11.96 11.96 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-1.875 0-3.628-.514-5.118-1.403l-.366-.218-3.764.981.997-3.67-.236-.378A9.713 9.713 0 0 1 2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75z"
              ></path>
              <path
                d="M17.498 14.382c-.301-.15-1.767-.867-2.04-.966-.273-.101-.473-.15-.673.15-.197.297-.771.964-.944 1.162-.175.195-.349.21-.646.075-.3-.15-1.263-.465-2.403-1.485-.888-.795-1.484-1.77-1.66-2.07-.174-.3-.019-.465.13-.615.136-.135.301-.345.451-.52.146-.181.194-.301.297-.496.1-.21.049-.375-.025-.524-.075-.15-.672-1.62-.922-2.206-.24-.566-.487-.5-.667-.506-.173-.008-.371-.01-.57-.01-.197 0-.52.074-.792.372-.271.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.71.305 1.263.482 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.69.249-1.289.176-1.408-.075-.13-.276-.21-.575-.36z"
              ></path>
            </svg>
            <a href={whatsappHref} class="hover:text-[var(--color-primary)]">
              {displayPhone}
            </a>
          </li>
          <li class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4 shrink-0"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="m3 7 9 6 9-6"></path>
            </svg>
            <a href="mailto:contacto@estarseguro.com" class="hover:text-[var(--color-primary)]">
              contacto@estarseguro.com
            </a>
          </li>
          <li class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4 shrink-0"
              aria-hidden="true"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Atención en todo el país</span>
          </li>
        </ul>
      </div>

      <div class="footer-anim-col" style="--anim-delay: 600ms">
        <h3 class="mb-8 text-lg font-semibold uppercase tracking-wider text-[var(--color-primary)]">
          Horario de atención
        </h3>
        <ul class="space-y-2 text-md text-white/80">
          <li>Lunes a Viernes</li>
          <li class="font-semibold text-white">9:00 a 18:00 hs</li>
          <li class="pt-2">Sábados</li>
          <li class="font-semibold text-white">9:00 a 13:00 hs</li>
        </ul>
      </div>
    </div>
  </Container>

  <div class="border-t border-white/10">
    <Container>
      <div class="flex flex-col items-center gap-3 py-5 sm:flex-row sm:gap-6">
        <div class="flex items-center gap-3">
          <a
            href={sanCristobalUrl}
            aria-label="San Cristóbal"
            class="text-white/70 transition-opacity hover:opacity-100"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="2" y1="12" x2="22" y2="12"></line>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
          </a>
          <a
            href={instagramUrl}
            aria-label="Instagram"
            class="text-white/70 transition-opacity hover:opacity-100"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a
            href={whatsappHref}
            aria-label="WhatsApp"
            class="text-white/70 transition-opacity hover:opacity-100"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              class="h-5 w-5"
              aria-hidden="true"
              fill="currentColor"
              stroke="none"
              stroke-width="1"
            >
              <path
                d="M12 0C5.373 0 0 5.373 0 12c0 2.118.549 4.106 1.522 5.823L0 24l6.335-1.652A11.96 11.96 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-1.875 0-3.628-.514-5.118-1.403l-.366-.218-3.764.981.997-3.67-.236-.378A9.713 9.713 0 0 1 2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75z"
              ></path>
              <path
                d="M17.498 14.382c-.301-.15-1.767-.867-2.04-.966-.273-.101-.473-.15-.673.15-.197.297-.771.964-.944 1.162-.175.195-.349.21-.646.075-.3-.15-1.263-.465-2.403-1.485-.888-.795-1.484-1.77-1.66-2.07-.174-.3-.019-.465.13-.615.136-.135.301-.345.451-.52.146-.181.194-.301.297-.496.1-.21.049-.375-.025-.524-.075-.15-.672-1.62-.922-2.206-.24-.566-.487-.5-.667-.506-.173-.008-.371-.01-.57-.01-.197 0-.52.074-.792.372-.271.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.71.305 1.263.482 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.69.249-1.289.176-1.408-.075-.13-.276-.21-.575-.36z"
              ></path>
            </svg>
          </a>
        </div>
        <p class="flex-1 text-center text-xs text-white/70">
          © <span id="footer-year"></span> Estar Seguro | Productores Asesores de Seguros. Todos los derechos reservados.
        </p>
        <p class="flex items-center gap-2 text-xs text-white/70">
          <span aria-hidden="true">·</span>
          <a
            href="https://rotative.com.ar"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--color-primary)] transition-colors"
          >by Rotative</a>
        </p>
      </div>
    </Container>
  </div>
</footer>

<style>
  .footer-anim-col {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 600ms ease-out,
      transform 600ms ease-out;
    transition-delay: var(--anim-delay, 0ms);
  }
  [data-footer].is-visible .footer-anim-col {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initFooter(): void {
    const footer = document.querySelector('[data-footer]');
    if (!(footer instanceof HTMLElement)) return;

    const yearEl = document.getElementById('footer-year');
    if (yearEl) {
      yearEl.textContent = String(new Date().getFullYear());
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            footer.classList.add('is-visible');
            observer.unobserve(footer);
            return;
          }
        }
      },
      { threshold: 0.1 }
    );

    observer.observe(footer);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFooter);
  } else {
    initFooter();
  }
</script>
