---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
  color?: 'default' | 'primary';
  size?: 'default' | 'large';
  eyebrowSize?: 'default' | 'large';
}

const {
  eyebrow,
  title,
  align = 'left',
  color = 'default',
  size = 'default',
  eyebrowSize = 'default',
} = Astro.props;

const alignment = align === 'center' ? 'text-center mx-auto' : 'text-left';
const titleColor = color === 'primary' ? 'text-[var(--color-primary)]' : 'text-[var(--color-text)]';
const titleSize = size === 'large' ? 'text-6xl sm:text-7xl' : 'text-3xl sm:text-4xl';
const eyebrowSizeClass = eyebrowSize === 'large' ? 'text-2xl' : 'text-xs';
const underlineAlign = align === 'center' ? 'mx-auto' : '';
---

<div class={`max-w-2xl ${alignment}`}>
  {
    eyebrow && (
      <p class={`mb-2 font-semibold uppercase tracking-widest text-[var(--color-primary)] ${eyebrowSizeClass}`}>
        {eyebrow}
      </p>
    )
  }
  <h2 class={`font-bold leading-tight ${titleSize} ${titleColor}`}>
    {title}
  </h2>
  <span class={`mt-3 block h-1 w-12 rounded-full bg-[var(--color-primary)] ${underlineAlign}`}></span>
</div>
