---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, align = 'left' } = Astro.props;

const alignment = align === 'center' ? 'text-center mx-auto' : 'text-left';
---

<div class={`max-w-2xl ${alignment}`}>
  {
    eyebrow && (
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-[var(--color-primary)]">
        {eyebrow}
      </p>
    )
  }
  <h2 class="text-3xl font-bold leading-tight text-[var(--color-text)] sm:text-4xl">
    {title}
  </h2>
  <span class="mt-3 block h-1 w-12 rounded-full bg-[var(--color-primary)]"></span>
</div>
