---
import { Image } from 'astro:assets';
import logo from '@assets/logo.webp';
import Button from '@components/Button.astro';
import Container from '@components/Container.astro';

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '';
const whatsappHref = whatsappNumber
  ? `https://wa.me/${whatsappNumber}`
  : 'https://wa.me/';
---

<header
  class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[var(--color-background)]/95 backdrop-blur"
>
  <style>
    .nav-link {
      border-bottom: 2px solid transparent;
      padding-bottom: 0.25rem;
      color: var(--color-text);
      transition: color 150ms, border-color 150ms;
    }
    .nav-link:hover {
      color: var(--color-primary);
    }
    .nav-link[aria-current='page'] {
      color: var(--color-primary);
      border-bottom-color: var(--color-primary);
    }
    #mobile-menu a[aria-current='page'] {
      color: var(--color-primary);
    }
    .mobile-menu {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition:
        max-height 300ms ease,
        opacity 200ms ease;
    }
    .mobile-menu.is-open {
      max-height: 500px;
      opacity: 1;
      pointer-events: auto;
    }
  </style>
  <Container>
    <div class="flex h-28 items-center gap-4">
      <a
        href="/"
        class="flex flex-col items-start"
        aria-label="Estar Seguro — Inicio"
      >
        <span class="flex items-center gap-3">
          <Image src={logo} alt="Logo de Estar Seguro" width={64} height={64} class="h-16 w-16 w-auto" />
          <span class="flex flex-col items-start leading-none">
            <span class="block text-4xl font-extrabold uppercase leading-none tracking-tight text-[var(--color-dark)]">Estar</span>
            <span class="mt-px block text-3xl font-extrabold uppercase leading-none tracking-tight text-[var(--color-primary)]">Seguro</span>
          </span>
        </span>
        <span class="mt-2 text-[14px] font-bold text-[var(--color-text)]">productores asesores de seguros</span>
      </a>

      <div class="ml-auto hidden items-center gap-6 md:flex">
        <nav class="flex items-center gap-6" aria-label="Navegación principal">
        <a
          href="/"
          aria-current="page"
          class="nav-link text-sm font-bold"
        >
          INICIO
        </a>

        <a
          href="#seguros"
          class="nav-link text-sm font-bold"
        >
          SEGUROS
        </a>

        <a
          href="#nosotros"
          class="nav-link text-sm font-bold"
        >
          NOSOTROS
        </a>
        <a
          href="#companias"
          class="nav-link text-sm font-bold"
        >
          COMPAÑÍAS
        </a>
      </nav>

      <div class="hidden md:block font-bold text-white">
        <Button variant="dark" href={whatsappHref} ariaLabel="Contactar por WhatsApp">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="h-4 w-4"
            aria-hidden="true"
            fill="currentColor"
            stroke="none"
            stroke-width="1"
          >
            <path
              d="M12 0C5.373 0 0 5.373 0 12c0 2.118.549 4.106 1.522 5.823L0 24l6.335-1.652A11.96 11.96 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-1.875 0-3.628-.514-5.118-1.403l-.366-.218-3.764.981.997-3.67-.236-.378A9.713 9.713 0 0 1 2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75z"
            ></path>
            <path
              d="M17.498 14.382c-.301-.15-1.767-.867-2.04-.966-.273-.101-.473-.15-.673.15-.197.297-.771.964-.944 1.162-.175.195-.349.21-.646.075-.3-.15-1.263-.465-2.403-1.485-.888-.795-1.484-1.77-1.66-2.07-.174-.3-.019-.465.13-.615.136-.135.301-.345.451-.52.146-.181.194-.301.297-.496.1-.21.049-.375-.025-.524-.075-.15-.672-1.62-.922-2.206-.24-.566-.487-.5-.667-.506-.173-.008-.371-.01-.57-.01-.197 0-.52.074-.792.372-.271.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.71.305 1.263.482 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.69.249-1.289.176-1.408-.075-.13-.276-.21-.575-.36z"
            ></path>
          </svg>
          WHATSAPP
        </Button>
      </div>
      </div>

      <button
        id="mobile-menu-toggle"
        type="button"
        class="ml-auto inline-flex h-10 w-10 items-center justify-center rounded-md text-[var(--color-text)] hover:bg-[var(--color-surface)] md:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          id="icon-hamburger"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-6 w-6"
          aria-hidden="true"
        >
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
        <svg
          id="icon-close"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden h-6 w-6"
          aria-hidden="true"
        >
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="6" y1="18" x2="18" y2="6"></line>
        </svg>
      </button>
    </div>
  </Container>

  <div
    id="mobile-menu"
    class="mobile-menu border-t border-[var(--color-border)] bg-[var(--color-background)] md:hidden"
  >
    <Container>
      <nav class="flex flex-col gap-1 py-4" aria-label="Navegación móvil">
        <a
          href="/"
          class="rounded-md px-3 py-2 text-sm font-medium text-[var(--color-text)] hover:bg-[var(--color-surface)]"
        >
          INICIO
        </a>
        <a
          href="#seguros"
          class="rounded-md px-3 py-2 text-sm font-medium text-[var(--color-text)] hover:bg-[var(--color-surface)]"
        >
          SEGUROS
        </a>
        <a
          href="#nosotros"
          class="rounded-md px-3 py-2 text-sm font-medium text-[var(--color-text)] hover:bg-[var(--color-surface)]"
        >
          NOSOTROS
        </a>
        <a
          href="#companias"
          class="rounded-md px-3 py-2 text-sm font-medium text-[var(--color-text)] hover:bg-[var(--color-surface)]"
        >
          COMPAÑÍAS
        </a>
        <a
          href={whatsappHref}
          class="mt-2 inline-flex items-center justify-center gap-2 rounded-md bg-[var(--color-dark)] px-4 py-2.5 text-sm font-semibold text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="h-4 w-4"
            aria-hidden="true"
            fill="currentColor"
            stroke="none"
            stroke-width="1"
          >
            <path
              d="M12 0C5.373 0 0 5.373 0 12c0 2.118.549 4.106 1.522 5.823L0 24l6.335-1.652A11.96 11.96 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-1.875 0-3.628-.514-5.118-1.403l-.366-.218-3.764.981.997-3.67-.236-.378A9.713 9.713 0 0 1 2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75z"
            ></path>
            <path
              d="M17.498 14.382c-.301-.15-1.767-.867-2.04-.966-.273-.101-.473-.15-.673.15-.197.297-.771.964-.944 1.162-.175.195-.349.21-.646.075-.3-.15-1.263-.465-2.403-1.485-.888-.795-1.484-1.77-1.66-2.07-.174-.3-.019-.465.13-.615.136-.135.301-.345.451-.52.146-.181.194-.301.297-.496.1-.21.049-.375-.025-.524-.075-.15-.672-1.62-.922-2.206-.24-.566-.487-.5-.667-.506-.173-.008-.371-.01-.57-.01-.197 0-.52.074-.792.372-.271.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.71.305 1.263.482 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.69.249-1.289.176-1.408-.075-.13-.276-.21-.575-.36z"
            ></path>
          </svg>
          WHATSAPP
        </a>
      </nav>
    </Container>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconBurger = document.getElementById('icon-hamburger');
  const iconClose = document.getElementById('icon-close');

  if (toggle && menu && iconBurger && iconClose) {
    const setOpen = (open: boolean): void => {
      menu.classList.toggle('is-open', open);
      iconBurger.classList.toggle('hidden', open);
      iconClose.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    };

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!isOpen);
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
  }

  function initActiveNavLink(): void {
    const navLinks = document.querySelectorAll<HTMLAnchorElement>('header nav a[href]');
    if (navLinks.length === 0) return;

    const sectionLinks: Array<{ link: HTMLAnchorElement; section: Element }> = [];
    let inicioLink: HTMLAnchorElement | null = null;

    navLinks.forEach((link) => {
      const href = link.getAttribute('href');
      if (!href) return;
      if (href === '/') {
        inicioLink = link;
      } else if (href.startsWith('#')) {
        const section = document.getElementById(href.slice(1));
        if (section) sectionLinks.push({ link, section });
      }
    });

    if (sectionLinks.length === 0) return;

    const setActive = (activeLink: HTMLAnchorElement | null): void => {
      navLinks.forEach((link) => {
        if (link === activeLink) {
          link.setAttribute('aria-current', 'page');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    const initialHash = window.location.hash;
    if (initialHash) {
      const match = sectionLinks.find(({ section }) => section.id === initialHash.slice(1));
      if (match) setActive(match.link);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

        if (visible[0]) {
          const match = sectionLinks.find(({ section }) => section === visible[0].target);
          if (match) setActive(match.link);
        } else {
          setActive(inicioLink);
        }
      },
      { rootMargin: '-30% 0px -70% 0px', threshold: 0 }
    );

    sectionLinks.forEach(({ section }) => observer.observe(section));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initActiveNavLink);
  } else {
    initActiveNavLink();
  }
</script>
