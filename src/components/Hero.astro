---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Container from '@components/Container.astro';
import QuoteForm from '@components/QuoteForm.astro';
import { insurances } from '@data/insurances';
import carrouselAuto from '@assets/carrousel-auto.webp';
import carrouselViajero from '@assets/carrousel-viajero.webp';
import carrouselMaquinaria from '@assets/carrousel-maquinaria.webp';

const slides: Array<{ asset: ImageMetadata; alt: string }> = [
  { asset: carrouselAuto, alt: 'Seguro de auto con descuento' },
  { asset: carrouselViajero, alt: 'Asistencia al viajero' },
  { asset: carrouselMaquinaria, alt: 'Seguros de maquinaria y otros' },
];

const total = slides.length;

const insuranceTags = insurances.map((i) => i.name).join(' · ');
const sancristobalUrl = 'https://www.sancristobal.com.ar/pas/estarseguro';
---

<section id="inicio" class="flex flex-col">
  <h1 class="sr-only">Las mejores compañías de seguros en un solo lugar — Estar Seguro</h1>
  <div
    x-data="carousel()"
    x-init="init()"
    @mouseenter="pause()"
    @mouseleave="resume()"
    @touchstart.passive="pause()"
    @touchend.passive="resume()"
    class="relative h-[70vh] min-h-[480px] w-full overflow-hidden md:h-[80vh] md:min-h-[600px]"
  >
    {slides.map((slide, i) => (
      <Image
        src={slide.asset}
        alt={slide.alt}
        x-cloak
        x-show={`active === ${i}`}
        x-transition:enter="transition-opacity duration-700 ease-in-out"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition-opacity duration-700 ease-in-out"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="absolute inset-0 h-full w-full object-cover"
        widths={[640, 960, 1280, 1920]}
        sizes="100vw"
        loading={i === 0 ? 'eager' : 'lazy'}
        decoding={i === 0 ? 'sync' : 'async'}
        fetchpriority={i === 0 ? 'high' : 'auto'}
        quality={90}
      />
    ))}

    <div class="absolute inset-0 bg-black/55" aria-hidden="true"></div>

    <div class="relative z-10 flex h-full items-center">
      <Container class="relative w-full h-full">
        <div
          x-show="active === 0"
          x-transition:enter="transition-all duration-700 ease-in-out delay-200"
          x-transition:enter-start="opacity-0 translate-y-4"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition-all duration-500 ease-in-out"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 -translate-y-4"
          class="absolute inset-0 flex items-center"
        >
          <div>
            <h2 class="text-3xl font-extrabold leading-tight text-white sm:text-4xl md:text-5xl">
              Asegurá tu auto
              <br />
              <span class="text-[var(--color-primary)]">con descuento</span>
            </h2>
            <a
              href={sancristobalUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center gap-2 rounded-md bg-[var(--color-primary)] px-6 py-3 text-sm font-semibold text-[var(--color-dark)] transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 focus-visible:ring-offset-black"
            >
              Acceder al descuento
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true"><polyline points="7 17 17 7"></polyline><polyline points="7 7 17 7"></polyline><polyline points="17 7 17 17"></polyline></svg>
            </a>
          </div>
        </div>

        <div
          x-show="active === 1"
          x-transition:enter="transition-all duration-700 ease-in-out delay-200"
          x-transition:enter-start="opacity-0 translate-y-4"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition-all duration-500 ease-in-out"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 -translate-y-4"
          class="absolute inset-0 flex items-center"
        >
          <div>
            <h2 class="text-3xl font-extrabold leading-tight text-white sm:text-4xl md:text-5xl">
              Cotizá tu
              <br />
              <span class="text-[var(--color-primary)]">asistencia al viajero</span>
            </h2>
            <a
              href="/asistencia-al-viajero"
              class="mt-6 inline-flex items-center gap-2 rounded-md bg-[var(--color-primary)] px-6 py-3 text-sm font-semibold text-[var(--color-dark)] transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 focus-visible:ring-offset-black"
            >
              Solicitar cotización
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
          </div>
        </div>

        <div
          x-show="active === 2"
          x-transition:enter="transition-all duration-700 ease-in-out delay-200"
          x-transition:enter-start="opacity-0 translate-y-4"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition-all duration-500 ease-in-out"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 -translate-y-4"
          class="absolute inset-0 flex items-center"
        >
          <div>
            <h2 class="text-3xl font-extrabold leading-tight text-white sm:text-4xl md:text-5xl">
              Cotizá tus otros
              <br />
              <span class="text-[var(--color-primary)]">seguros acá</span>
            </h2>
            <button
              type="button"
              @click="scrollToCotizacion()"
              class="mt-6 inline-flex items-center gap-2 rounded-md bg-[var(--color-primary)] px-6 py-3 text-sm font-semibold text-[var(--color-dark)] transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 focus-visible:ring-offset-black"
            >
              Completar formulario
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </button>
          </div>
        </div>
      </Container>
    </div>

    <button
      type="button"
      @click="prev()"
      class="absolute left-4 top-1/2 z-20 hidden -translate-y-1/2 items-center justify-center rounded-full bg-black/40 p-3 text-white transition-colors hover:bg-black/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white md:flex"
      aria-label="Imagen anterior"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    <button
      type="button"
      @click="next()"
      class="absolute right-4 top-1/2 z-20 hidden -translate-y-1/2 items-center justify-center rounded-full bg-black/40 p-3 text-white transition-colors hover:bg-black/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white md:flex"
      aria-label="Siguiente imagen"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>

    <div class="absolute bottom-6 left-1/2 z-20 hidden -translate-x-1/2 items-center gap-2 md:flex">
      {Array.from({ length: total }).map((_, i) => (
        <button
          type="button"
          @click={`goTo(${i})`}
          x-bind:aria-current={`active === ${i} ? 'true' : 'false'`}
          x-bind:aria-label={`'Ir a imagen ' + ${i + 1}`}
          x-bind:class={`active === ${i} ? 'bg-white' : 'bg-white/40 hover:bg-white/70'`}
          class="h-2.5 w-2.5 rounded-full transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
          aria-label={`Ir a imagen ${i + 1}`}
        ></button>
      ))}
    </div>
  </div>

  <div id="cotizacion" class="bg-gray-50 py-12 sm:py-16">
    <Container>
      <div class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-12 md:grid-cols-2 md:gap-16">
        <div class="flex flex-col justify-center">
          <h2 class="text-3xl font-extrabold leading-tight text-[var(--color-text)] sm:text-4xl">
            Conseguí los mejores seguros al <span class="text-[var(--color-primary)]">mejor precio</span>
          </h2>
          <p class="mt-6 text-base leading-relaxed text-[var(--color-text)] opacity-80">
            {insuranceTags} y más.
          </p>
          <p class="mt-4 text-base leading-relaxed text-[var(--color-text)] opacity-70">
            Asesoramiento personalizado sin costo. Trabajamos con las mejores compañías del país.
          </p>
        </div>
        <div class="xl:pt-4">
          <QuoteForm />
        </div>
      </div>
    </Container>
  </div>
</section>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>

<script>
  import Alpine from 'alpinejs';

  Alpine.data('carousel', () => ({
    active: 0,
    total: 3,
    timer: null as number | null,
    init(this: { start: () => void }) {
      this.start();
    },
    start(this: { stop: () => void; next: () => void; timer: number | null }) {
      this.stop();
      this.timer = window.setInterval(() => this.next(), 5000);
    },
    stop(this: { timer: number | null }) {
      if (this.timer !== null) {
        window.clearInterval(this.timer);
        this.timer = null;
      }
    },
    pause(this: { stop: () => void }) {
      this.stop();
    },
    resume(this: { start: () => void }) {
      this.start();
    },
    next(this: { active: number; total: number }) {
      this.active = (this.active + 1) % this.total;
    },
    prev(this: { active: number; total: number }) {
      this.active = (this.active - 1 + this.total) % this.total;
    },
    goTo(this: { active: number }, i: number) {
      this.active = i;
    },
    scrollToCotizacion() {
      const el = document.getElementById('cotizacion');
      if (el) {
        el.scrollIntoView({ behavior: 'smooth' });
      }
    },
  }));

  window.Alpine = Alpine;
  Alpine.start();
</script>
