---
import { Image } from 'astro:assets';
import SectionTitle from '@components/SectionTitle.astro';
import Button from '@components/Button.astro';
import nosotrosImg from '@assets/nosotros.webp';

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '';
const fixedMessage = 'Hola, estoy interesado en recibir asesoramiento sobre seguros.';
const ctaHref = whatsappNumber
  ? `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(fixedMessage)}`
  : '#';

const diferenciales = [
  'Asesoramiento personalizado y sin costo',
  'Trabajamos con las mejores compañías del país',
  'Atención rápida y cercana',
  'Gestión integral de siniestros',
  'Cobertura en todo el país',
];
---

<section id="nosotros" class="relative">
  <div
    class="absolute inset-0 grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-[35%_65%]"
    aria-hidden="true"
  >
    <div class="bg-[var(--color-dark)]"></div>
    <div class="relative">
      <Image
        src={nosotrosImg}
        alt=""
        loading="lazy"
        decoding="async"
        widths={[480, 800, 1200]}
        sizes="(min-width: 1024px) 65vw, 100vw"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div
        class="absolute inset-0 bg-gradient-to-l from-transparent via-black/10 to-[var(--color-dark)]/60"
      ></div>
    </div>
  </div>

  <div
    class="relative mx-auto grid max-w-7xl grid-cols-1 lg:grid-cols-2 xl:grid-cols-[35%_65%]"
  >
    <div class="bg-[var(--color-dark)] px-6 py-16 text-white sm:px-8 sm:py-20 xl:pe-28 xl:ps-8">
      <SectionTitle
        eyebrow="¿Por qué elegirnos?"
        title="Asesoramiento que marca la diferencia"
        size="large"
        eyebrowSize="large"
      />
      <ul class="mt-10 space-y-4">
        {
          diferenciales.map((item) => (
            <li class="flex items-start gap-5 text-lg text-white/90">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                class="mt-1 h-8 w-8 shrink-0"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" fill="var(--color-primary)"></circle>
                <polyline
                  points="8 12 11 15 16 9"
                  fill="none"
                  stroke="var(--color-dark)"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></polyline>
              </svg>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="relative min-h-[400px] lg:min-h-0">
      <div
        class="absolute bottom-4 left-4 right-4 rounded-lg bg-[var(--color-primary)] p-6 text-[var(--color-dark)] shadow-2xl sm:bottom-8 sm:right-8 sm:left-auto sm:max-w-lg sm:p-8"
      >
        <div class="flex items-start gap-5">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="h-12 w-12 shrink-0"
            aria-hidden="true"
            fill="var(--color-dark)"
            stroke="none"
          >
            <path
              d="M12 0C5.373 0 0 5.373 0 12c0 2.118.549 4.106 1.522 5.823L0 24l6.335-1.652A11.96 11.96 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-1.875 0-3.628-.514-5.118-1.403l-.366-.218-3.764.981.997-3.67-.236-.378A9.713 9.713 0 0 1 2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75z"
            ></path>
            <path
              d="M17.498 14.382c-.301-.15-1.767-.867-2.04-.966-.273-.101-.473-.15-.673.15-.197.297-.771.964-.944 1.162-.175.195-.349.21-.646.075-.3-.15-1.263-.465-2.403-1.485-.888-.795-1.484-1.77-1.66-2.07-.174-.3-.019-.465.13-.615.136-.135.301-.345.451-.52.146-.181.194-.301.297-.496.1-.21.049-.375-.025-.524-.075-.15-.672-1.62-.922-2.206-.24-.566-.487-.5-.667-.506-.173-.008-.371-.01-.57-.01-.197 0-.52.074-.792.372-.271.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.71.305 1.263.482 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.69.249-1.289.176-1.408-.075-.13-.276-.21-.575-.36z"
            ></path>
          </svg>
          <div class="min-w-0 flex-1">
            <p class="mb-1 text-xs font-bold uppercase tracking-widest text-[var(--color-dark)]/70">
              ¿Tenés dudas?
            </p>
            <p class="mb-5 text-base font-semibold leading-snug sm:text-lg">
              Escribinos por WhatsApp y te asesoramos sin compromiso.
            </p>
            <Button variant="dark" href={ctaHref} ariaLabel="Hablar por WhatsApp">
              Hablar por WhatsApp
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  #nosotros h2 {
    color: #ffffff;
  }
  @media (min-width: 1280px) {
    #nosotros h2 {
      font-size: 2.25rem;
      line-height: 2.5rem;
    }
  }
</style>
