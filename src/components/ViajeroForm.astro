---
---

<form class="js-viajero-form mt-8 space-y-4" novalidate>
  <input
    name="nombre"
    type="text"
    placeholder="Nombre y apellido *"
    aria-label="Nombre completo"
    aria-required="true"
    autocomplete="name"
    class="viajero-input w-full rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2.5 text-sm focus-visible:border-[var(--color-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)]"
  />
  <input
    name="cantidadPersonas"
    type="number"
    min="1"
    placeholder="¿Cuántas personas viajan? *"
    aria-label="Cantidad de personas"
    aria-required="true"
    class="viajero-input w-full rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2.5 text-sm focus-visible:border-[var(--color-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)]"
  />
  <input
    name="edades"
    type="text"
    placeholder="Edades de los viajeros (ej: 35, 28, 4) *"
    aria-label="Edades"
    aria-required="true"
    class="viajero-input w-full rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2.5 text-sm focus-visible:border-[var(--color-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)]"
  />
  <input
    name="destino"
    type="text"
    placeholder="¿A dónde viajan? *"
    aria-label="Destino"
    aria-required="true"
    class="viajero-input w-full rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2.5 text-sm focus-visible:border-[var(--color-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)]"
  />
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <input
      name="fechaDesde"
      type="date"
      aria-label="Fecha de salida"
      aria-required="true"
      placeholder="Fecha de salida"
      class="viajero-input w-full rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2.5 text-sm focus-visible:border-[var(--color-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)]"
    />
    <input
      name="fechaHasta"
      type="date"
      aria-label="Fecha de regreso"
      aria-required="true"
      placeholder="Fecha de regreso"
      class="viajero-input w-full rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2.5 text-sm focus-visible:border-[var(--color-primary)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)]"
    />
  </div>
  <p class="text-xs text-[var(--color-text)] opacity-60 !mt-2">
    * Fecha de salida y Fecha de regreso
  </p>
  <button
    type="submit"
    class="inline-flex w-full items-center justify-center gap-2 rounded-md bg-[var(--color-primary)] px-5 py-3 text-sm font-semibold text-[var(--color-dark)] transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      class="h-4 w-4"
      aria-hidden="true"
    >
      <path
        d="M12 0C5.373 0 0 5.373 0 12c0 2.118.549 4.106 1.522 5.823L0 24l6.335-1.652A11.96 11.96 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-1.875 0-3.628-.514-5.118-1.403l-.366-.218-3.764.981.997-3.67-.236-.378A9.713 9.713 0 0 1 2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75z"
        fill="var(--color-text)"
      ></path>
      <path
        d="M17.498 14.382c-.301-.15-1.767-.867-2.04-.966-.273-.101-.473-.15-.673.15-.197.297-.771.964-.944 1.162-.175.195-.349.21-.646.075-.3-.15-1.263-.465-2.403-1.485-.888-.795-1.484-1.77-1.66-2.07-.174-.3-.019-.465.13-.615.136-.135.301-.345.451-.52.146-.181.194-.301.297-.496.1-.21.049-.375-.025-.524-.075-.15-.672-1.62-.922-2.206-.24-.566-.487-.5-.667-.506-.173-.008-.371-.01-.57-.01-.197 0-.52.074-.792.372-.271.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.71.305 1.263.482 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.69.249-1.289.176-1.408-.075-.13-.276-.21-.575-.36z"
        fill="var(--color-text)"
      ></path>
    </svg>
    Enviar consulta por WhatsApp
  </button>
  <p class="flex items-center justify-center gap-2 text-xs opacity-70">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="h-4 w-4"
      aria-hidden="true"
    >
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
    </svg>
    Tus datos están 100% protegidos
  </p>
</form>

<style>
  .viajero-input.field-error {
    border-color: #dc2626;
  }
  .viajero-input.field-error:focus-visible {
    border-color: #dc2626;
    box-shadow: 0 0 0 2px rgba(220, 38, 38, 0.3);
  }
</style>

<script>
  import { validateViajeroForm, buildViajeroWhatsAppMessage, type ViajeroFormData } from '@scripts/quoteForm';

  document.querySelectorAll('.js-viajero-form').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fd = new FormData(form as HTMLFormElement);
      const data: ViajeroFormData = {
        nombre: String(fd.get('nombre') ?? ''),
        cantidadPersonas: String(fd.get('cantidadPersonas') ?? ''),
        edades: String(fd.get('edades') ?? ''),
        destino: String(fd.get('destino') ?? ''),
        fechaDesde: String(fd.get('fechaDesde') ?? ''),
        fechaHasta: String(fd.get('fechaHasta') ?? ''),
      };
      const result = validateViajeroForm(data);
      form.querySelectorAll('.viajero-input').forEach((el) => el.classList.remove('field-error'));
      if (!result.valid) {
        if (result.errors.nombre) form.querySelector<HTMLElement>('[name="nombre"]')?.classList.add('field-error');
        if (result.errors.cantidadPersonas) form.querySelector<HTMLElement>('[name="cantidadPersonas"]')?.classList.add('field-error');
        if (result.errors.edades) form.querySelector<HTMLElement>('[name="edades"]')?.classList.add('field-error');
        if (result.errors.destino) form.querySelector<HTMLElement>('[name="destino"]')?.classList.add('field-error');
        if (result.errors.fechaDesde) form.querySelector<HTMLElement>('[name="fechaDesde"]')?.classList.add('field-error');
        if (result.errors.fechaHasta) form.querySelector<HTMLElement>('[name="fechaHasta"]')?.classList.add('field-error');
        return;
      }
      const message = buildViajeroWhatsAppMessage(data);
      const number = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '';
      window.location.href = `https://wa.me/${number}?text=${message}`;
    });
  });
</script>
