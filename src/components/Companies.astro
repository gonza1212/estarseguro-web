---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Container from '@components/Container.astro';
import SectionTitle from '@components/SectionTitle.astro';
import { companies } from '@data/companies';
import sanCristobalLogo from '@assets/san-cristobal.webp';
import mercantilLogo from '@assets/mercantil.webp';
import andinaLogo from '@assets/andina.webp';
import rivadaviaLogo from '@assets/rivadavia.webp';
import expertaLogo from '@assets/experta.webp';

const logoMap: Record<string, ImageMetadata> = {
  'san-cristobal': sanCristobalLogo,
  mercantil: mercantilLogo,
  andina: andinaLogo,
  rivadavia: rivadaviaLogo,
  experta: expertaLogo,
};
---

<section
  id="companias"
  data-companies
  class="bg-[var(--color-background)] py-16 sm:py-20"
>
  <Container>
    <div class="flex flex-col items-center">
      <div
        class="companies-anim-item w-full"
        style="--anim-delay: 0ms"
      >
        <SectionTitle
          title="Compañías con las que trabajamos"
          align="center"
          color="primary"
        />
      </div>
      <div
        class="mt-12 grid w-full grid-cols-1 items-center gap-x-6 gap-y-8 px-2 sm:grid-cols-3 sm:gap-x-8 sm:gap-y-10 sm:px-0 md:grid-cols-5"
      >
        {
          companies.map((company, i) => (
            <div
              class="companies-anim-item flex items-center justify-center"
              style={`--anim-delay: ${(i + 1) * 200}ms`}
            >
              <Image
                src={logoMap[company.logo]}
                alt={company.name}
                loading="lazy"
                decoding="async"
                widths={[160, 320, 480, 640]}
                sizes="(min-width: 1024px) 200px, (min-width: 640px) 160px, 50vw"
                class="h-20 w-auto max-w-full object-contain sm:h-24"
              />
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>

<style>
  .companies-anim-item {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 600ms ease-out,
      transform 600ms ease-out;
    transition-delay: var(--anim-delay, 0ms);
  }
  [data-companies].is-visible .companies-anim-item {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initCompaniesAnimation(): void {
    const section = document.querySelector('[data-companies]');
    if (!(section instanceof HTMLElement)) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            section.classList.add('is-visible');
            observer.unobserve(section);
            return;
          }
        }
      },
      { threshold: 0.1 }
    );

    observer.observe(section);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCompaniesAnimation);
  } else {
    initCompaniesAnimation();
  }
</script>
