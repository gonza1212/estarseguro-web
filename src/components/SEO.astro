---
import { getImage } from 'astro:assets';
import logo from '@assets/logo.webp';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site ?? 'http://localhost').toString();
const logoAsset = await getImage({ src: logo, width: 256, format: 'webp' });
const resolvedLogoUrl = new URL(logoAsset.src, Astro.site ?? 'http://localhost').toString();
const resolvedOgImage = ogImage ?? resolvedLogoUrl;
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '';
const publicEmail = 'contacto@estarseguro.com';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'InsuranceAgency',
  '@id': `${siteOrigin}#insurance-agency`,
  name: 'Estar Seguro',
  url: siteOrigin || undefined,
  logo: resolvedLogoUrl,
  image: resolvedLogoUrl,
  description,
  telephone: whatsappNumber || undefined,
  email: publicEmail,
  areaServed: { '@type': 'Country', name: 'Argentina' },
  employee: [
    { '@type': 'Person', name: 'Arias Alberto Gastón' },
    { '@type': 'Person', name: 'Valeria Melisa Millapinda' },
  ],
};

const authorJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${siteOrigin}#webpage`,
  url: siteOrigin || undefined,
  name: title,
  isPartOf: { '@id': `${siteOrigin}#website` },
  author: {
    '@type': 'Organization',
    name: 'Rotative',
    url: 'https://rotative.com.ar',
  },
};
---

<title>{title}</title>
<link rel="icon" href="/favicon.ico" type="image/x-icon" />
<meta name="description" content={description} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:type" content="website" />
<meta property="og:locale" content="es_AR" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />
<link rel="canonical" href={canonicalUrl} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(authorJsonLd)} />
